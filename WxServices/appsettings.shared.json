{
  "_README": [
    "CANONICAL shared configuration for every WxServices app and service. THIS file —",
    "WxServices/appsettings.shared.json — is the single source of truth that drives the",
    "whole system: the four Windows services and WxManager/WxViewer all read it at startup",
    "(AddJsonFile, required). Each project links this one file and copies it into its own",
    "output/release directory at build time, so the copies that sit beside each service's",
    "binaries (bin/..., release/.../appsettings.shared.json) are BUILD-GENERATED — DO NOT EDIT",
    "THEM; they are overwritten on every build. Make all changes HERE, then rebuild/redeploy.",
    "Per-machine secrets and overrides belong in the optional appsettings.local.json under",
    "InstallRoot, never in this shared file. (This _README key is ignored by the .NET config",
    "binder and by the deploy script's JSON parse — it carries documentation, not settings.)"
  ],
  "InstallRoot": "C:\\HarderWare",
  "ConnectionStrings": {
    "WeatherData": "Server=.\\SQLEXPRESS;Database=WeatherData;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Database": {
    "StartupRetry": {
      "MaxAttempts": 12,
      "DelaySecondsSchedule": [ 5, 10, 20, 30, 30, 30, 30, 30, 30, 30, 30 ]
    }
  },
  "Fetch": {
    "IntervalMinutes": 10,
    "HomeIcao": "KDWH",
    "HomeLatitude": 31.5,
    "HomeLongitude": -97.0,
    "BoundingBoxDegrees": 9,
    "LocalityBoxDegrees": 2.0,
    "RegionSouth": 22.0,
    "RegionNorth": 50.0,
    "RegionWest": -126.0,
    "RegionEast": -65.0,
    "MetarRetentionDays": 3,
    "TafRetentionDays": 3
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587
  },
  "Claude": {
    "Model": "claude-sonnet-4-6",
    "MessagesEndpoint": "https://api.anthropic.com/v1/messages",
    "ApiVersion": "2023-06-01",
    "MaxTokens": 2048
  },
  "Gfs": {
    "IntervalMinutes": 10,
    "DelayHours": 3.5,
    "Wgrib2Path": "",
    "MaxForecastHours": 120,
    "RetainModelRuns": 1
  },
  "Telemetry": {
    "Enabled": true,
    "OtlpEndpoint": "http://localhost:4318/v1/metrics"
  },
  "WxVis": {
    "CondaPythonExe": "C:\\Users\\PaulH\\miniconda3\\envs\\wxvis\\python.exe",
    "AnalysisMapMinutePastHour": 10,
    "MapExtent": "conus",
    "ForecastPollIntervalSeconds": 30,
    "PlotRetentionDays": 7,
    "ZoomLevels": 3,
    "DbDriver": "ODBC Driver 17 for SQL Server"
  },
  "Monitor": {
    "IntervalMinutes": 5,
    "AlertEmail": "PaulHarder2@gmail.com",
    "AlertOnSeverity": "ERROR",
    "AlertCooldownMinutes": 60,
    "MetarStalenessThresholdMinutes": 120,
    "WatchedServices": [
      {
        "Name": "WxParser.Svc",
        "HeartbeatMaxAgeMinutes": 90
      },
      {
        "Name": "WxReport.Svc",
        "HeartbeatMaxAgeMinutes": 15
      }
    ]
  },
  "Report": {
    "IntervalMinutes": 5,
    "DefaultLanguage": "English",
    "DefaultScheduledSendHours": "7",
    "MinGapMinutes": 90,
    "PrecipRateThresholdMmHr": 0.1,
    "SignificanceGate": {
      "Mode": "Enforce",
      "TempDeltaDegF": [ 5, 7, 10, 12 ],
      "WindDeltaKt": [ 12, 15, 18, 20 ],
      "WindAdvisoryKt": 25,
      "HeatAdvisoryDegF": 100
    },
    "Recipients": []
  },
  "WxManager": {
    "MaxNearbyStationsInLookup": 40,
    "StationLookupRadiusKm": 150.0,
    "MaxDisplayStations": 5,
    "DefaultTimezone": "America/Chicago",
    "UserAgent": "WxManager/1.0",
    "AwcMetarEndpoint": "https://aviationweather.gov/api/data/metar",
    "AwcMetarHours": 6,
    "SuccessMessageDismissMs": 3000
  }
}
