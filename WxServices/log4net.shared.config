<?xml version="1.0" encoding="utf-8"?>
<!--
  Shared log4net configuration for all WxServices components.
  The log file path is set at runtime via log4net.GlobalContext.Properties["LogFile"]
  before Logger.Initialise() calls XmlConfigurator.
-->
<log4net>
  <appender name="RollingFile" type="log4net.Appender.RollingFileAppender">
    <file type="log4net.Util.PatternString" value="%property{LogFile}" />
    <appendToFile value="true" />
    <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
    <rollingStyle value="Size" />
    <maximumFileSize value="10MB" />
    <maxSizeRollBackups value="10" />
    <staticLogFileName value="true" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%utcdate{yyyy-MM-dd HH:mm:ss.fff} %-5level %message%newline" />
    </layout>
  </appender>
  <root>
    <!-- DEBUG is a deliberate operational choice across all services while
         WxServices stabilizes: full diagnostics are worth the log volume until
         the system is proven stable and scalable. Revert to INFO once it
         settles (and enable DEBUG via override when troubleshooting). -->
    <level value="DEBUG" />
    <appender-ref ref="RollingFile" />
  </root>
</log4net>
