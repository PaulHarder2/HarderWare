<Window x:Class="WxViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WxViewer" Height="750" Width="1400"
        Background="#1a1a1a"
        WindowStyle="None"
        WindowState="Maximized">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      NonClientFrameEdges="None"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="4,2"/>
        </Style>

        <!-- TabControl / TabItem dark theme -->
        <Style TargetType="TabControl">
            <Setter Property="Background"         Value="#1a1a1a"/>
            <Setter Property="BorderBrush"         Value="#333333"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="Padding"             Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground"         Value="#c0c0c0"/>
            <Setter Property="Background"         Value="#252525"/>
            <Setter Property="BorderBrush"        Value="#333333"/>
            <Setter Property="Padding"            Value="12,5"/>
            <Setter Property="FontSize"           Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                Margin="2,2,0,0">
                            <ContentPresenter x:Name="cp"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1a1a1a"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#555555"/>
                                <Setter Property="Foreground"                  Value="#ffffff"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#303030"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Suppress the ToolBar gripper (dots); keep overflow chevron visible
             so buttons are accessible when the toolbar is narrow. -->
        <Style TargetType="ToolBar">
            <Setter Property="ToolBarTray.IsLocked" Value="True"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding"           Value="8,3"/>
            <Setter Property="Margin"            Value="2,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"        Value="#e0e0e0"/>
        </Style>

        <!-- Window chrome button — minimize and maximize/restore -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#c0c0c0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Focusable"       Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#3c3c3c"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window chrome button — close (red hover) -->
        <Style x:Key="CloseWinCtrlButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#c0c0c0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Focusable"       Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#c42b1c"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#a82315"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── Header / logo + window controls ─────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#0d0d0d"
                BorderBrush="#333333" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="14,8">
                    <Run Text="HarderWare" FontWeight="Bold"   FontSize="18" Foreground="#e0e0e0"/>
                    <Run Text=" WxViewer"  FontWeight="Normal" FontSize="18" Foreground="#c8c8c8"/>
                    <Run x:Name="VersionRun" FontWeight="Light" FontSize="13" Foreground="#909090"/>
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <Button Style="{StaticResource WinCtrlButton}"
                            ToolTip="Minimize"
                            Content="&#x2012;"
                            Click="MinimizeButton_Click"/>
                    <Button ToolTip="Restore / Maximize" Click="MaxRestoreButton_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
                                <Setter Property="Content" Value="&#x25A1;"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WindowState,
                                                 RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="Maximized">
                                        <Setter Property="Content" Value="&#x2752;"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Style="{StaticResource CloseWinCtrlButton}"
                            ToolTip="Close"
                            Content="&#x2715;"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Status bar ────────────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Background="#111111">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#808080" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Tab area ─────────────────────────────────────────────────────── -->
        <TabControl>

            <!-- ── Maps tab ──────────────────────────────────────────────────── -->
            <TabItem Header="Maps">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Analysis pane ───────────────────────────────────────── -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Analysis control bar -->
                        <ToolBarTray Grid.Row="0" Background="#252525">
                            <ToolBar Band="0" BandIndex="0" Background="#252525" Foreground="#e0e0e0">

                                <TextBlock Text="Analysis:" Foreground="#d0d0d0"
                                           VerticalAlignment="Center" Margin="4,0,2,0"/>
                                <ComboBox Width="118"
                                          ItemsSource="{Binding AnalysisLabels}"
                                          SelectedItem="{Binding SelectedAnalysisLabel}"
                                          DisplayMemberPath="Label"/>

                                <Separator/>

                                <Button Command="{Binding AnalysisStepBackCommand}"
                                        ToolTip="Step back" Content="◀" Width="24"
                                        Margin="1,0" Foreground="#e0e0e0"/>

                                <Button Command="{Binding AnalysisPlayPauseCommand}"
                                        ToolTip="Play / Pause" Width="60" Margin="1,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Foreground" Value="#e0e0e0"/>
                                            <Setter Property="Content"    Value="▶ Play"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAnalysisPlaying}" Value="True">
                                                    <Setter Property="Content" Value="⏸ Pause"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Command="{Binding AnalysisStepForwardCommand}"
                                        ToolTip="Step forward" Content="▶" Width="24"
                                        Margin="1,0" Foreground="#e0e0e0"/>

                                <Separator/>

                                <TextBlock Text="Speed:" Foreground="#d0d0d0"
                                           VerticalAlignment="Center" Margin="2,0,2,0"/>
                                <ComboBox Width="72"
                                          ItemsSource="{Binding SpeedOptions}"
                                          SelectedItem="{Binding SelectedAnalysisSpeed}"
                                          DisplayMemberPath="Label"/>

                                <Separator/>

                                <Slider Width="110"
                                        Minimum="0"
                                        Maximum="{Binding MaxAnalysisFrameIndex}"
                                        Value="{Binding AnalysisFrameIndex, Mode=TwoWay,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        IsDirectionReversed="True"
                                        Focusable="False"
                                        VerticalAlignment="Center"
                                        Margin="0,0,2,0"/>
                                <TextBlock Text="{Binding AnalysisFrameLabel}"
                                           Foreground="#e0e0e0"
                                           VerticalAlignment="Center"
                                           MinWidth="130"
                                           Margin="0,0,4,0"/>

                                <Separator/>
                                <TextBlock Text="{Binding AnalysisZoomLabel}"
                                           Foreground="#60b0ff" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="2,0,4,0"/>
                                <Button Content="Reset Zoom"
                                        ToolTip="Reset zoom to fit window (or double-click map)"
                                        Command="{Binding ResetAnalysisZoomCommand}"
                                        Foreground="#e0e0e0" Padding="4,3" Margin="1,0"/>
                                <ToggleButton x:Name="LinkPanesToggle"
                                              Content="Link Panes"
                                              ToolTip="Sync zoom and pan between both panes"
                                              IsChecked="True"
                                              Padding="4,3" Margin="1,0">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Foreground" Value="#808080"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Foreground" Value="#40cc40"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>

                            </ToolBar>
                        </ToolBarTray>

                        <!-- Analysis image (zoomable) -->
                        <Border x:Name="AnalysisViewport" Grid.Row="1"
                                ClipToBounds="True" Background="#111111"
                                MouseWheel="MapViewport_MouseWheel"
                                MouseLeftButtonDown="MapViewport_MouseLeftButtonDown"
                                MouseLeftButtonUp="MapViewport_MouseLeftButtonUp"
                                MouseMove="MapViewport_MouseMove"
                                >
                            <Grid>
                                <TextBlock Text="No analysis map selected"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#404040" FontSize="15"/>
                                <Image x:Name="AnalysisMapImage"
                                       Source="{Binding AnalysisImage}"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderTransformOrigin="0,0">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="AnalysisScale"/>
                                            <TranslateTransform x:Name="AnalysisTranslate"/>
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4"
                                  HorizontalAlignment="Stretch"
                                  Background="#444444"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"/>

                    <!-- ── Forecast pane ────────────────────────────────────────── -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Forecast control bar -->
                        <ToolBarTray Grid.Row="0" Background="#252525">
                            <ToolBar Band="0" BandIndex="0" Background="#252525" Foreground="#e0e0e0">

                                <TextBlock Text="GFS Run:" Foreground="#d0d0d0"
                                           VerticalAlignment="Center" Margin="4,0,2,0"/>
                                <ComboBox Width="145"
                                          ItemsSource="{Binding ForecastRuns}"
                                          SelectedItem="{Binding SelectedForecastRun}"
                                          DisplayMemberPath="Label"/>

                                <Separator/>

                                <Button Command="{Binding ForecastStepBackCommand}"
                                        ToolTip="Step back" Content="◀" Width="24"
                                        Margin="1,0" Foreground="#e0e0e0"/>

                                <Button Command="{Binding ForecastPlayPauseCommand}"
                                        ToolTip="Play / Pause" Width="60" Margin="1,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Foreground" Value="#e0e0e0"/>
                                            <Setter Property="Content"    Value="▶ Play"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsForecastPlaying}" Value="True">
                                                    <Setter Property="Content" Value="⏸ Pause"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Command="{Binding ForecastStepForwardCommand}"
                                        ToolTip="Step forward" Content="▶" Width="24"
                                        Margin="1,0" Foreground="#e0e0e0"/>

                                <Separator/>

                                <TextBlock Text="Speed:" Foreground="#d0d0d0"
                                           VerticalAlignment="Center" Margin="2,0,2,0"/>
                                <ComboBox Width="72"
                                          ItemsSource="{Binding SpeedOptions}"
                                          SelectedItem="{Binding SelectedForecastSpeed}"
                                          DisplayMemberPath="Label"/>

                                <Separator/>

                                <TextBlock Text="Hour:" Foreground="#d0d0d0"
                                           VerticalAlignment="Center" Margin="2,0,2,0"/>
                                <Slider Width="110"
                                        Minimum="0"
                                        Maximum="{Binding MaxForecastFrameIndex}"
                                        Value="{Binding ForecastFrameIndex, Mode=TwoWay,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Focusable="False"
                                        VerticalAlignment="Center"
                                        Margin="0,0,2,0"/>
                                <TextBlock Text="{Binding ForecastFrameLabel}"
                                           Foreground="#e0e0e0"
                                           VerticalAlignment="Center"
                                           MinWidth="150"
                                           Margin="0,0,4,0"/>

                                <Separator/>
                                <TextBlock Text="{Binding ForecastZoomLabel}"
                                           Foreground="#60b0ff" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="2,0,4,0"/>
                                <Button Content="Reset Zoom"
                                        ToolTip="Reset zoom to fit window (or double-click map)"
                                        Command="{Binding ResetForecastZoomCommand}"
                                        Foreground="#e0e0e0" Padding="4,3" Margin="1,0"/>

                            </ToolBar>
                        </ToolBarTray>

                        <!-- Forecast image (zoomable) -->
                        <Border x:Name="ForecastViewport" Grid.Row="1"
                                ClipToBounds="True" Background="#111111"
                                MouseWheel="MapViewport_MouseWheel"
                                MouseLeftButtonDown="MapViewport_MouseLeftButtonDown"
                                MouseLeftButtonUp="MapViewport_MouseLeftButtonUp"
                                MouseMove="MapViewport_MouseMove"
                                >
                            <Grid>
                                <TextBlock Text="No forecast map selected"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#404040" FontSize="15"/>
                                <Image x:Name="ForecastMapImage"
                                       Source="{Binding ForecastImage}"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderTransformOrigin="0,0">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="ForecastScale"/>
                                            <TranslateTransform x:Name="ForecastTranslate"/>
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>
                        </Border>
                    </Grid>

                </Grid>
            </TabItem>

            <!-- ── Meteograms tab ─────────────────────────────────────────────── -->
            <TabItem Header="Meteograms">
                <Grid Background="#1a1a1a">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Meteogram control bar -->
                    <ToolBarTray Grid.Row="0" Background="#252525">
                        <ToolBar Band="0" BandIndex="0" Background="#252525" Foreground="#e0e0e0">
                            <TextBlock Text="Run:" Foreground="#d0d0d0"
                                       VerticalAlignment="Center" Margin="4,0,4,0"/>
                            <ComboBox Width="200"
                                      ItemsSource="{Binding MeteogramRuns}"
                                      SelectedItem="{Binding SelectedMeteogramRun}"
                                      DisplayMemberPath="Label"/>
                            <Separator Margin="8,0"/>
                            <TextBlock Text="Recipient:" Foreground="#d0d0d0"
                                       VerticalAlignment="Center" Margin="4,0,4,0"/>
                            <ComboBox Width="240"
                                      ItemsSource="{Binding Recipients}"
                                      SelectedItem="{Binding SelectedRecipient}"
                                      DisplayMemberPath="DisplayText"/>
                        </ToolBar>
                    </ToolBarTray>

                    <!-- Meteogram list — vertically scrollable; each image horizontally scrollable -->
                    <ScrollViewer x:Name="MeteogramScrollViewer"
                                  Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="#1a1a1a">
                        <ItemsControl x:Name="MeteogramItemsControl"
                                      ItemsSource="{Binding MeteogramItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,12,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                        <Setter Property="Background" Value="#1e3a5c"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="8,4,0,4"
                                                        VerticalAlignment="Center">
                                                <Button Content="Recipients"
                                                        Click="RecipientsButton_Click"
                                                        Padding="6,2"
                                                        FontSize="11"
                                                        Margin="0,0,8,0"
                                                        Foreground="#d0d0d0"
                                                        Background="#3a3a3a"
                                                        BorderBrush="#555555"/>
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#c8c8c8"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Disabled"
                                                          PreviewMouseWheel="MeteogramImageScrollViewer_PreviewMouseWheel">
                                                <Image Source="{Binding FullImage}"
                                                       Stretch="None"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       HorizontalAlignment="Left"/>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Placeholder when no meteograms are available -->
                    <TextBlock Grid.Row="1"
                               Text="No meteograms available"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#404040" FontSize="15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MeteogramItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
