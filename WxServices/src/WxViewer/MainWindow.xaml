<Window x:Class="WxViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WxViewer" Height="750" Width="1400"
        Background="#1a1a1a"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="4,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding"           Value="8,3"/>
            <Setter Property="Margin"            Value="2,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
        <ToolBarTray DockPanel.Dock="Top" Background="#252525">
            <ToolBar Band="0" BandIndex="0" Background="#252525"
                     Foreground="#e0e0e0">

                <!-- Analysis selector -->
                <TextBlock Text="Analysis:" Foreground="#a0a0a0"
                           VerticalAlignment="Center" Margin="4,0,4,0"/>
                <ComboBox Width="270"
                          ItemsSource="{Binding AnalysisMaps}"
                          SelectedItem="{Binding SelectedAnalysis}"
                          DisplayMemberPath="Label"/>

                <Separator/>

                <!-- Forecast run selector -->
                <TextBlock Text="GFS Run:" Foreground="#a0a0a0"
                           VerticalAlignment="Center" Margin="4,0,4,0"/>
                <ComboBox Width="200"
                          ItemsSource="{Binding ForecastRuns}"
                          SelectedItem="{Binding SelectedRun}"
                          DisplayMemberPath="Label"/>

                <Separator/>

                <!-- Forecast hour slider -->
                <TextBlock Text="Hour:" Foreground="#a0a0a0"
                           VerticalAlignment="Center" Margin="4,0,4,0"/>
                <Slider Width="220"
                        Minimum="0"
                        Maximum="{Binding MaxFrameIndex}"
                        Value="{Binding FrameIndex, Mode=TwoWay,
                                        UpdateSourceTrigger=PropertyChanged}"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0"/>
                <TextBlock Text="{Binding FrameLabel}"
                           Foreground="#e0e0e0"
                           VerticalAlignment="Center"
                           MinWidth="215"
                           Margin="0,0,8,0"/>

                <Separator/>

                <!-- Playback controls -->
                <Button Command="{Binding StepBackCommand}"
                        ToolTip="Step back  (←)"
                        Content="◀" Width="30"/>

                <Button Command="{Binding PlayPauseCommand}"
                        ToolTip="Play / Pause  (Space)"
                        Width="72">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Content" Value="▶  Play"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Content" Value="⏸  Pause"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Command="{Binding StepForwardCommand}"
                        ToolTip="Step forward  (→)"
                        Content="▶" Width="30"/>

                <Separator/>

                <TextBlock Text="Speed:" Foreground="#a0a0a0"
                           VerticalAlignment="Center" Margin="4,0,4,0"/>
                <ComboBox Width="90"
                          ItemsSource="{Binding SpeedOptions}"
                          SelectedItem="{Binding SelectedSpeed}"
                          DisplayMemberPath="Label"/>

            </ToolBar>
        </ToolBarTray>

        <!-- ── Status bar ────────────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Background="#111111">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="#808080" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Map area ──────────────────────────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Analysis map -->
            <Grid Grid.Column="0" Background="#111111">
                <TextBlock Text="No analysis map selected"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#404040" FontSize="15"/>
                <Image Source="{Binding AnalysisImage}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="#444444"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Right: Forecast map -->
            <Grid Grid.Column="2" Background="#111111">
                <TextBlock Text="No forecast map selected"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#404040" FontSize="15"/>
                <Image Source="{Binding ForecastImage}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>

        </Grid>
    </DockPanel>
</Window>
