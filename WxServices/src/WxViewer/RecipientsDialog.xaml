<Window x:Class="WxViewer.RecipientsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recipients"
        Width="420"
        SizeToContent="Height"
        MinHeight="120"
        MaxHeight="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#252525">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0"
                  x:Name="RecipientGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  CanUserSortColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#383838"
                  RowBackground="#1a1a1a"
                  AlternatingRowBackground="#212121"
                  Background="#1a1a1a"
                  Foreground="#c8c8c8"
                  BorderBrush="#404040"
                  BorderThickness="1">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"   Value="#2d2d2d"/>
                    <Setter Property="Foreground"   Value="#e0e0e0"/>
                    <Setter Property="FontWeight"   Value="SemiBold"/>
                    <Setter Property="Padding"      Value="8,5"/>
                    <Setter Property="BorderBrush"  Value="#404040"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Foreground"      Value="#c8c8c8"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background"   Value="#1e3a5c"/>
                            <Setter Property="Foreground"   Value="#ffffff"/>
                            <Setter Property="BorderBrush"  Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1e3a5c"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"       Binding="{Binding RecipientId}" MinWidth="80"  Width="Auto"/>
                <DataGridTextColumn Header="Name"     Binding="{Binding Name}"        MinWidth="120" Width="*"/>
                <DataGridTextColumn Header="Language" Binding="{Binding Language}"    MinWidth="80"  Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="1"
                Content="Close"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                Padding="16,5"
                Foreground="#d0d0d0"
                Background="#3a3a3a"
                BorderBrush="#555555"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
