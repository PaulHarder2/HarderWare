<UserControl x:Class="WxManager.AnnouncementTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>

        <!-- ── Messages ───────────────────────────────────────────────────────── -->
        <Border x:Name="MessagesBorder" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1"
                CornerRadius="3" Margin="8,8,8,0" Padding="10,8">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Dismiss" Width="80"
                        VerticalAlignment="Top" Margin="12,0,0,0"
                        Click="DismissBtn_Click"/>
                <TextBox x:Name="MessagesText" TextWrapping="Wrap"
                         IsReadOnly="True" BorderThickness="0"
                         Foreground="#856404"
                         VerticalContentAlignment="Center"
                         IsTabStop="False">
                    <!-- Override the global IsReadOnly trigger so the background stays transparent -->
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </DockPanel>
        </Border>

        <!-- ── Button row ─────────────────────────────────────────────────────── -->
        <DockPanel DockPanel.Dock="Bottom" Margin="8,4,8,8" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Cancel" Width="80" Margin="0,0,10,0"
                        Click="CancelBtn_Click"/>
                <Button x:Name="SendBtn" Content="Send" Width="80"
                        Click="SendBtn_Click"/>
            </StackPanel>
            <TextBlock x:Name="ProgressText" VerticalAlignment="Center"
                       Foreground="#909090" FontStyle="Italic" TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <!-- ── Announcement text area ─────────────────────────────────────────── -->
        <GroupBox Header="Announcement" Margin="8,8,8,4">
            <TextBox x:Name="AnnouncementBox"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="13" Padding="6"
                     VerticalContentAlignment="Top"/>
        </GroupBox>

    </DockPanel>
</UserControl>
