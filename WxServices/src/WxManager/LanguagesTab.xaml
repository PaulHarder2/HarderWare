<UserControl x:Class="WxManager.LanguagesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8"
                   Text="Languages a recipient may be assigned. Enable a language to support it — its report templates are generated automatically on the next report cycle, and it becomes assignable once Ready. Select a supported language to see its status. Disable is blocked while any recipient is still assigned it."/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- All languages (not yet enabled) -->
            <DockPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock DockPanel.Dock="Top" Text="All languages" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox DockPanel.Dock="Top" x:Name="FilterBox" Margin="0,0,0,4"
                         TextChanged="FilterBox_TextChanged"
                         ToolTip="Filter by name or ISO code"/>
                <ListBox x:Name="AllList" DisplayMemberPath="DisplayName"/>
            </DockPanel>

            <!-- Move buttons -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                <Button x:Name="EnableBtn" Content="Enable &#x25B6;" Width="110" Margin="0,4"
                        Click="EnableBtn_Click" ToolTip="Enable the selected language (move to Supported)"/>
                <Button x:Name="DisableBtn" Content="&#x25C0; Disable" Width="110" Margin="0,4"
                        Click="DisableBtn_Click" ToolTip="Disable the selected language (move to All languages)"/>
            </StackPanel>

            <!-- Supported (enabled) — name + generation-status label per row -->
            <DockPanel Grid.Column="2" Margin="8,0,0,0">
                <TextBlock DockPanel.Dock="Top" Text="Supported" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ListBox x:Name="SupportedList" SelectionChanged="SupportedList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Display}"/>
                                <TextBlock Text="{Binding StatusLabel}" Margin="8,0,0,0" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>

        <!-- Status / guidance for the selected supported language (WX-172) -->
        <Border Grid.Row="2" x:Name="DetailPanel" Visibility="Collapsed" Margin="0,8,0,0"
                Padding="8" BorderBrush="#404040" BorderThickness="1" Background="#252525">
            <StackPanel>
                <TextBlock x:Name="DetailHeader" FontWeight="SemiBold" TextWrapping="Wrap"/>
                <TextBlock x:Name="DetailText" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" x:Name="StatusText" TextWrapping="Wrap" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
