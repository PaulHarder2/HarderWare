<UserControl x:Class="WxManager.TranslationQaTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WxManager"
             Background="#1a1a1a">
    <DockPanel LastChildFill="True">

        <!-- ── Top bar: package selector + trust/common info (WX-219) ── -->
        <Border DockPanel.Dock="Top" Background="#1e1e1e" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="12,10">
            <!-- One thin line: selector + Refresh, then the trust info. Fixed items dock left, counts pin
                 right, the variable-length confidence note fills the middle and ellipsises (full text on
                 hover) so the row never wraps. -->
            <DockPanel x:Name="TrustPanel" LastChildFill="True">
                <TextBlock Text="Judge package:" DockPanel.Dock="Left" Foreground="#c8c8c8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="PackageSelector" DockPanel.Dock="Left" Width="240" VerticalAlignment="Center" SelectionChanged="PackageSelector_SelectionChanged"/>
                <Button x:Name="RefreshButton" DockPanel.Dock="Left" Content="Refresh" Margin="10,0,8,0" Padding="10,2" VerticalAlignment="Center" Click="RefreshButton_Click"/>
                <local:RerunQaButton x:Name="RerunButton" DockPanel.Dock="Left" Margin="0,0,16,0"/>
                <TextBlock x:Name="LangText"   DockPanel.Dock="Left" Foreground="#c8c8c8" VerticalAlignment="Center" Margin="0,0,18,0"/>
                <TextBlock x:Name="SourceText" DockPanel.Dock="Left" Foreground="#c8c8c8" VerticalAlignment="Center" Margin="0,0,18,0"/>
                <Border x:Name="ConfidenceBadge" DockPanel.Dock="Left" CornerRadius="3" Padding="6,1" Margin="0,0,12,0" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="ConfidenceText" Foreground="#ffffff" FontWeight="SemiBold"/>
                </Border>
                <TextBlock x:Name="CountsText" DockPanel.Dock="Right" Foreground="#c8c8c8" VerticalAlignment="Center" Margin="18,0,0,0"/>
                <TextBlock x:Name="ConfidenceNote" Foreground="#909090" FontStyle="Italic" VerticalAlignment="Center"
                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            </DockPanel>
        </Border>

        <!-- ── Empty-state message (shown when no package is selected / none found) ── -->
        <TextBlock x:Name="EmptyState" DockPanel.Dock="Top" Foreground="#909090" Margin="14,16"
                   TextWrapping="Wrap" Visibility="Collapsed"/>

        <!-- ── Sub-tabs: one per scenario (added in code-behind), then Vocabulary ── -->
        <TabControl x:Name="SubTabs">
            <TabItem Header="Vocabulary" x:Name="VocabTab">
                <DataGrid x:Name="VocabGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          CanUserResizeRows="False" BorderThickness="0" RowHeaderWidth="0" Margin="10,0,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Status"  Binding="{Binding StatusLabel}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="6,0,0,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{Binding StatusBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Token"   Binding="{Binding Token}" Width="150"/>
                        <DataGridTextColumn Header="English" Binding="{Binding EnglishPhrase}" Width="140"/>
                        <DataGridTextColumn Header="Target"  Binding="{Binding TargetPhrase}" Width="150"/>
                        <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="*"/>
                        <DataGridTextColumn Header="Suggestion" Binding="{Binding Suggestion}" Width="160"/>
                        <DataGridTemplateColumn Header="Apply" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding ApplyLabel}" Margin="4,2" Padding="6,1"
                                            IsEnabled="{Binding CanApply}" Click="CopyToDb_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>