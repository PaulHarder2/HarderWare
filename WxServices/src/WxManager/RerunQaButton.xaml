<UserControl x:Class="WxManager.RerunQaButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Center">
    <UserControl.Resources>
        <!-- WX-235: the in-progress sweep. The chevron strip sits one tile (16px) left of the button and
             translates +16 over the loop, so right-pointing chevrons march rightward seamlessly. -->
        <Storyboard x:Key="Sweep" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ChevronShift" Storyboard.TargetProperty="X"
                             From="0" To="16" Duration="0:0:0.7"/>
        </Storyboard>
    </UserControl.Resources>
    <Button x:Name="Btn" Click="OnClick" Padding="12,3" MinWidth="100" Margin="10,0,8,0" VerticalAlignment="Center">
        <Grid MinWidth="76">
            <Border x:Name="ChevronHost" ClipToBounds="True" Visibility="Collapsed">
                <StackPanel x:Name="ChevronStrip" Orientation="Horizontal"
                            HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-16,0,0,0">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="ChevronShift" X="0"/>
                    </StackPanel.RenderTransform>
                </StackPanel>
            </Border>
            <TextBlock x:Name="Label" Text="Rerun QA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Button>
</UserControl>
