<UserControl x:Class="WxManager.ConfigureTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1a1a1a" Foreground="#c8c8c8">

    <UserControl.Resources>
        <!-- WX-315: one style for every field this tab shows but cannot change, so "read-only"
             looks the same everywhere and a future field gets it by applying the style rather than
             by remembering separate attributes. Foreground is the same muted grey used for hint
             text — on this dark panel a lighter grey would still read as editable.

             Deliberately NOT Focusable="False": read-only must still mean selectable. These fields
             exist to be READ, and some are longer than their box (the connection string in
             particular), so without focus the tail would be unreachable — no horizontal scroll, no
             select, no copy into SSMS or a note. IsReadOnly alone rejects edits while leaving the
             caret, selection and Ctrl+C working, which is exactly the intent. -->
        <Style x:Key="ReadOnlyValue" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Foreground" Value="#909090"/>
            <Setter Property="IsReadOnlyCaretVisible" Value="True"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="System Configuration"
                       FontSize="18" FontWeight="SemiBold" Foreground="#e0e0e0"/>
            <TextBlock Text="Settings on this tab are saved to the database and are read by all services and desktop apps. Greyed fields are set by the setup script (WxServices.Setup) and are shown here for reference only."
                       FontSize="11" Foreground="#909090" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Scrollable settings form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>

                <!-- ── Paths ─────────────────────────────────────────────── -->
                <GroupBox Header="Paths" Margin="0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Display-only (WX-69): InstallRoot is set in appsettings.shared.json before
                             deploy (or via the WXSERVICES_INSTALL_ROOT env var), not from this tab. The
                             Conda Python / wgrib2 path fields were removed — those deps live in the containers. -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Install Root" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtInstallRoot" Style="{StaticResource ReadOnlyValue}" Margin="0,4"
                                   ToolTip="Set in appsettings.shared.json before deploy (or the WXSERVICES_INSTALL_ROOT env var). Read-only here — it cannot be changed from this tab."/>
                    </Grid>
                </GroupBox>

                <!-- ── Location ──────────────────────────────────────────── -->
                <GroupBox Header="Home Location and Fetch Region  (set by the setup script — re-run it to change)" Margin="0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Home ICAO" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtHomeIcao" Style="{StaticResource ReadOnlyValue}" Margin="0,4" Width="100" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Home Latitude" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxtHomeLatitude" Style="{StaticResource ReadOnlyValue}" Margin="0,4" Width="120" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Home Longitude" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtHomeLongitude" Style="{StaticResource ReadOnlyValue}" Margin="0,4" Width="120" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Bounding Box (deg)" VerticalAlignment="Center" Margin="0,4"
                                   ToolTip="Fallback half-width when explicit region bounds are not set."/>
                        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="TxtBoundingBoxDeg" Style="{StaticResource ReadOnlyValue}" Margin="0,4" Width="80" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Region South" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtRegionSouth" Style="{StaticResource ReadOnlyValue}" Margin="0,4" Width="120" HorizontalAlignment="Left"
                                   ToolTip="Explicit southern latitude bound. Leave empty to derive from home lat/lon."/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Region North" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="5" Grid.Column="1" x:Name="TxtRegionNorth" Style="{StaticResource ReadOnlyValue}" Margin="0,4" Width="120" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Region West" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="6" Grid.Column="1" x:Name="TxtRegionWest" Style="{StaticResource ReadOnlyValue}" Margin="0,4" Width="120" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Region East" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="7" Grid.Column="1" x:Name="TxtRegionEast" Style="{StaticResource ReadOnlyValue}" Margin="0,4" Width="120" HorizontalAlignment="Left"/>
                    </Grid>
                </GroupBox>

                <!-- ── Database ─────────────────────────────────────────��── -->
                <GroupBox Header="Database  (native / management connection — the services use their own)" Margin="0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Connection String" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtConnectionString" Style="{StaticResource ReadOnlyValue}" Margin="0,4"/>
                        <Button    Grid.Row="0" Grid.Column="2" Content="Test" Width="60" Margin="4,4,0,4"
                                   Click="TestDbButton_Click"/>
                    </Grid>
                </GroupBox>

                <!-- ── Email (SMTP) ──────────────────────────────────────── -->
                <GroupBox Header="Email (SMTP)" Margin="0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="SMTP Host" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtSmtpHost" Margin="0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="SMTP Port" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxtSmtpPort" Margin="0,4" Width="80" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Username" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtSmtpUsername" Margin="0,4"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Password" VerticalAlignment="Center" Margin="0,4"/>
                        <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="TxtSmtpPassword" Margin="0,4"
                                     Background="White" Foreground="Black" BorderBrush="#888888" Padding="3,2"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="From Address" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtSmtpFromAddress" Margin="0,4"/>
                        <Button    Grid.Row="4" Grid.Column="2" Content="Test" Width="60" Margin="4,4,0,4"
                                   Click="TestSmtpButton_Click"/>
                    </Grid>
                </GroupBox>

                <!-- ── Claude API ─────────────────���──────────────────────── -->
                <GroupBox Header="Claude API" Margin="0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="API Key" VerticalAlignment="Center" Margin="0,4"/>
                        <PasswordBox Grid.Row="0" Grid.Column="1" x:Name="TxtClaudeApiKey" Margin="0,4"
                                     Background="White" Foreground="Black" BorderBrush="#888888" Padding="3,2"/>
                        <Button    Grid.Row="0" Grid.Column="2" Content="Test" Width="60" Margin="4,4,0,4"
                                   Click="TestClaudeButton_Click"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Model" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxtClaudeModel" Style="{StaticResource ReadOnlyValue}" Margin="0,4"/>
                    </Grid>
                </GroupBox>

                <!-- ── Map ───────────────────────────────────────────────── -->
                <!-- Address Lookup (WX-322): the What3Words key moved out of
                     appsettings.local.json into GlobalSettings, where every other secret lives. -->
                <GroupBox Header="Address Lookup (What3Words)" Margin="0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="What3Words API Key" VerticalAlignment="Center" Margin="0,4"/>
                        <PasswordBox Grid.Row="0" Grid.Column="1" x:Name="TxtWhat3WordsApiKey" Margin="0,4"
                                     ToolTip="Resolves ///word.word.word addresses on the Recipients tab. Stored in the GlobalSettings database row, not in a file (WX-322)."/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Map Rendering  (set by the setup script)" Margin="0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Map Extent" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtMapExtent" Style="{StaticResource ReadOnlyValue}" Margin="0,4"
                                   ToolTip="Preset name (conus, south_central) or W,E,S,N coordinates. Leave empty for auto-fit."/>
                    </Grid>
                </GroupBox>

                <!-- ── Monitor ───────────────────────────────────────────���─ -->
                <GroupBox Header="Monitoring" Margin="0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Alert Email" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtAlertEmail" Margin="0,4"/>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       FontSize="12" Foreground="#909090" Margin="0,0,16,0"/>
            <Button x:Name="SaveButton" Content="Save Configuration"
                    Width="150" IsEnabled="False" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
