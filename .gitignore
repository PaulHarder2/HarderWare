# Personal notes — not for source control
Notes/

# Machine-local secrets — never commit
appsettings.local.json

# Build/format scratch artifacts — dotnet format can leave "<name>.tmp.<pid>.<hex>"
# files beside the file it rewrites; they must never be committed (a blanket
# `git add -A` would otherwise sweep them in). WX-188.
*.tmp.*

# Credential-file-type exclusions (WX-91) — keep secrets out by file-type,
# not just by path, so a future credential-bearing file is excluded by
# default rather than needing a one-off rule.
*.env
*.pfx
*.p12
*.key
*.pem
id_rsa*
*.cer
secrets.*

# Claude Code per-project state — runtime lock + accreted permission allowlist
.claude/

# Python bytecode
__pycache__/
*.pyc

# WSL path artifact — langcount temp project landed here due to path resolution quirk
C:/
